TASKBOARD_APP_NAME=rclone-taskboard
APP_TIMEZONE=Europe/Moscow
TASKBOARD_RCLONE_CONFIG=/root/.config/rclone/rclone.conf
TASKBOARD_ENABLE_SCHEDULER=true
TASKBOARD_STANDARD_INTERVAL_MINUTES=1
TASKBOARD_HEAVY_HOUR=3
TASKBOARD_WATCHER_DEBOUNCE_SECONDS=45
TASKBOARD_COPY_STARTUP_DELAY_SECONDS=60
TASKBOARD_COPY_MIN_START_INTERVAL_SECONDS=60
TASKBOARD_DEFAULT_TIMEOUT_SECONDS=3600
TASKBOARD_OUTPUT_TAIL_CHARS=8000
TASKBOARD_DRY_RUN=false
# TASKBOARD_API_TOKEN=change-me
